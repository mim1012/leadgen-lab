js.msg);\n        }\n      }\n    });\n    return false;\n  }\n</script>\n<script type=\"text/javascript\" async=\"\" src=\"https://ssl.pstatic.net/melona/libs/gfp-nac-module/synchronizer.js\"></script><script type=\"text/javascript\" async=\"\" src=\"https://googleads.g.doubleclick.net/pagead/viewthroughconversion/11008812130/?random=1781092247477&amp;cv=11&amp;fst=1781092247477&amp;bg=ffffff&amp;guid=ON&amp;async=1&amp;en=gtag.config&amp;gtm=45be6641za200xec&amp;gcd=13l3l3l3l1l1&amp;dma=0&amp;tag_exp=0~115938465~115938468&amp;u_w=3440&amp;u_h=1440&amp;url=https%3A%2F%2Fadpot.kr%2Fpc%2Fjoin%2Flogin.html&amp;rcb=3&amp;frm=0&amp;tiba=%EC%95%A0%EB%93%9C%ED%8C%9F%20%EB%A1%9C%EA%B7%B8%EC%9D%B8&amp;hn=www.googleadservices.com&amp;npa=0&amp;pscdl=noapi&amp;auid=2083864359.1781092247&amp;uaa=x86&amp;uab=64&amp;uafvl=Google%2520Chrome%3B149.0.7827.53%7CChromium%3B149.0.7827.53%7CNot)A%253BBrand%3B24.0.0.0&amp;uamb=0&amp;uam=&amp;uap=Windows&amp;uapv=19.0.0&amp;uaw=0&amp;data=event%3Dgtag.config&amp;ept=9&amp;rfmt=3&amp;fmt=4\"></script></head>\n<body>\n<div class=\"wrap\">\n\n        <div class=\"header\">\n        <div class=\"top\">\n            <ul class=\"top_L\">\n                <li><a href=\"/pc/intro/adpot3.html\" onclick=\"blur()\">애드팟 소개</a></li>\n                <li><a href=\"/pc/etc/tool_tip.html\" onclick=\"blur()\">마케팅 툴&amp;팁</a></li>\n            </ul>\n            <div class=\"top_L2\"></div>\n            <ul class=\"top_R\">\n                <li><a href=\"/pc/my/my_camp.html\">내캠페인</a></li>\n                <li><a href=\"/pc/my/point_his.html\">수익금내역</a></li>\n                <li><a href=\"/pc/my/point.html\">출금신청</a></li>\n                <li><a href=\"/pc/center/notice.html\">고객센터</a></li>                \n            </ul>\n        </div>\n        <!--h_top-->\n        <div class=\"middle\">\n            <h1><a href=\"/\"><img src=\"/images/common/logo.jpg\" alt=\"애드팟\"><img src=\"/images/common/season3.jpg\" alt=\"시즌2 오픈플랫폼\"></a></h1>\n            <ol